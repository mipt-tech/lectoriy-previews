{
  "name": "psami-lectorium-thumbnails",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.js",
  "scripts": {
    "build": "node node_modules/webpack/bin/webpack.js -p --config ./webpack.config.js",
    "start": "node node_modules/webpack-dev-server/bin/webpack-dev-server.js --config ./webpack.config.js --hot --port 3000",
    "report": "node node_modules/webpack/bin/webpack.js --profile --json > stats.json && webpack-bundle-analyzer ./stats.json",
    "postbuild": "node -e \"const fs=require('fs'),p='public';if(fs.existsSync(p+'/index.html')){fs.copyFileSync(p+'/index.html',p+'/404.html');}try{fs.closeSync(fs.openSync(p+'/.nojekyll','a'));}catch(e){}\""
  },
  "dependencies": {
    "@material-ui/core": "4.12.4",
    "@material-ui/icons": "4.11.3",
    "@material-ui/lab": "4.0.0-alpha.61",
    "classnames": "2.2.6",
    "just-last": "2.1.0",
    "konva": "4.1.3",
    "react": "16.14.0",
    "react-dom": "16.14.0",
    "react-dropzone": "10.2.1",
    "react-gluejar": "1.0.0",
    "react-hot-loader": "4.12.21",
    "react-konva": "16.12.0-0",
    "react-map-interaction": "1.3.2",
    "react-redux": "7.2.1",
    "react-throttle-render": "2.0.0",
    "redux": "4.0.5"
  },
  "devDependencies": {
    "babel-eslint": "10.1.0",
    "@babel/core": "7.24.7",
    "@babel/plugin-proposal-class-properties": "7.18.6",
    "@babel/plugin-proposal-nullish-coalescing-operator": "7.18.6",
    "@babel/plugin-proposal-object-rest-spread": "7.20.7",
    "@babel/plugin-proposal-optional-chaining": "7.21.0",
    "@babel/preset-env": "7.24.7",
    "@babel/preset-react": "7.24.7",
    "babel-loader": "8.3.0",
    "clean-webpack-plugin": "3.0.0",
    "css-loader": "4.2.2",
    "eslint": "7.7.0",
    "eslint-config-prettier": "6.11.0",
    "eslint-plugin-prettier": "3.1.4",
    "eslint-plugin-react": "7.20.6",
    "file-loader": "6.0.0",
    "html-webpack-plugin": "4.4.0",
    "prettier": "2.1.1",
    "style-loader": "1.2.1",
    "webpack": "4.44.1",
    "webpack-bundle-analyzer": "4.8.0",
    "webpack-cli": "3.3.12",
    "webpack-dev-server": "3.11.0"
  }
}
